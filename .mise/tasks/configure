#!/usr/bin/env bash
#MISE description="Configure the LLVM/Clang Wasm build and dprint plugin build."
set -euo pipefail

mise deps llvm

repo_root="$PWD"
llvm_version="${LLVM_VERSION:-22.1.7}"
source_root="third_party/llvm-project-${llvm_version}.src"
build_dir="${LLVM_WASM_BUILD_DIR:-build/llvm-wasm}"

pixi run cmake \
  -S "$source_root/llvm" \
  -B "$build_dir" \
  -G Ninja \
  -C "$repo_root/cmake/llvm-wasm-cache.cmake"

pixi run cmake --fresh -S . -B build/plugin -G Ninja \
  -DCMAKE_TOOLCHAIN_FILE=cmake/toolchains/wasm32-unknown-unknown.cmake
