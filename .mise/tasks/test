#!/usr/bin/env bash
#MISE description="Test the built dprint plugin."
#MISE depends=["build"]
set -euo pipefail

import_count="$(
  pixi run wasm-objdump -x build/plugin.wasm |
    awk '
      /^Import\[/ {
        value = $0
        sub(/^Import\[/, "", value)
        sub(/\].*$/, "", value)
        print value
        found = 1
      }
      END {
        if (!found) print "0"
      }
    '
)"

if [[ "$import_count" != "0" ]]; then
  echo "expected zero wasm imports, found $import_count" >&2
  pixi run wasm-objdump -x build/plugin.wasm >&2
  exit 1
fi

node tests/plugin_abi_test.js build/plugin.wasm
bash tests/dprint_cli_test.sh
